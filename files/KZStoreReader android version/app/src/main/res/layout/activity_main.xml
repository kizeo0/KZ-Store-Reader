<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/rootScrollView"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0D0D0D"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="12dp"
        android:paddingBottom="16dp">

        <!-- Botón ⋮ (esquina superior derecha) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingTop="4dp">

            <View android:layout_width="0dp" android:layout_height="0dp" android:layout_weight="1"/>

            <TextView
                android:id="@+id/btnOverflowMenu"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:text="⋮"
                android:textSize="22sp"
                android:textColor="#AAAAAA"
                android:gravity="center"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Más opciones"/>

        </LinearLayout>

        <!-- Logo + título -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingTop="8dp"
            android:paddingBottom="16dp">

            <ImageView
                android:id="@+id/ivMainLogo"
                android:layout_width="120dp"
                android:layout_height="120dp"
                android:scaleType="fitCenter"
                android:contentDescription="KZ Store Reader logo"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="KZ Store Reader"
                android:textColor="#FFFFFF"
                android:textSize="24sp"
                android:textStyle="bold"
                android:fontFamily="monospace"
                android:gravity="center"
                android:layout_marginTop="6dp"/>

            <TextView
                android:id="@+id/tvSubtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="By KiZeo — PS3 Store Emulator"
                android:textColor="#444444"
                android:textSize="11sp"
                android:gravity="center"
                android:layout_marginTop="2dp"/>

        </LinearLayout>

        <!-- Línea divisoria -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#222222"
            android:layout_marginBottom="16dp"/>

        <!-- Fila 1: Mis Tiendas + Extraer PKG -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:weightSum="2"
            android:layout_marginBottom="8dp">

            <androidx.cardview.widget.CardView
                android:id="@+id/cardStores"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="6dp"
                app:cardBackgroundColor="#1A1A1A"
                app:cardCornerRadius="14dp"
                app:cardElevation="4dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:minHeight="130dp"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="12dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="🏪" android:textSize="32sp"/>
                    <TextView
                        android:id="@+id/tvCardStoresTitle"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Mis Tiendas"
                        android:textColor="#FFFFFF" android:textStyle="bold" android:textSize="13sp"
                        android:layout_marginTop="6dp" android:gravity="center"/>
                    <TextView
                        android:id="@+id/tvStoreCount"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Sin tiendas aún"
                        android:textColor="#666666" android:textSize="10sp"
                        android:gravity="center" android:layout_marginTop="4dp"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:id="@+id/cardPkg"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="6dp"
                app:cardBackgroundColor="#1A1A1A"
                app:cardCornerRadius="14dp"
                app:cardElevation="4dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:minHeight="130dp"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="12dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="📦" android:textSize="32sp"/>
                    <TextView
                        android:id="@+id/tvCardPkgTitle"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Extraer PKG"
                        android:textColor="#FFFFFF" android:textStyle="bold" android:textSize="13sp"
                        android:layout_marginTop="6dp" android:gravity="center"/>
                    <TextView
                        android:id="@+id/tvCardPkgSub"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Desempaqueta un\narchivo .pkg"
                        android:textColor="#666666" android:textSize="10sp"
                        android:gravity="center" android:layout_marginTop="4dp"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>
        </LinearLayout>

        <!-- Fila 2: Abrir XML + PSN DB -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:weightSum="2"
            android:layout_marginBottom="8dp">

            <androidx.cardview.widget.CardView
                android:id="@+id/cardXml"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="6dp"
                app:cardBackgroundColor="#1A1A1A"
                app:cardCornerRadius="14dp"
                app:cardElevation="4dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:minHeight="130dp"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="12dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="📂" android:textSize="32sp"/>
                    <TextView
                        android:id="@+id/tvCardXmlTitle"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Abrir XML"
                        android:textColor="#FFFFFF" android:textStyle="bold" android:textSize="13sp"
                        android:layout_marginTop="6dp" android:gravity="center"/>
                    <TextView
                        android:id="@+id/tvCardXmlSub"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Carga el XML principal\nde una tienda"
                        android:textColor="#666666" android:textSize="10sp"
                        android:gravity="center" android:layout_marginTop="4dp"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:id="@+id/cardPsn"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="6dp"
                app:cardBackgroundColor="#1A1A1A"
                app:cardCornerRadius="14dp"
                app:cardElevation="4dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:minHeight="130dp"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="12dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="🌐" android:textSize="32sp"/>
                    <TextView
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="PSN Database"
                        android:textColor="#FFFFFF" android:textStyle="bold" android:textSize="13sp"
                        android:layout_marginTop="6dp" android:gravity="center"/>
                    <TextView
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="By Luan Teles"
                        android:textColor="#666666" android:textSize="10sp"
                        android:gravity="center" android:layout_marginTop="4dp"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>
        </LinearLayout>

        <!-- Tarjeta FTP (ancho completo, más compacta) -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cardFtp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="65dp"
            android:layout_marginBottom="8dp"
            app:cardBackgroundColor="#1A1A1A"
            app:cardCornerRadius="14dp"
            app:cardElevation="4dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="12dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="📡" android:textSize="26sp"/>
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="12dp">
                    <TextView
                        android:id="@+id/tvCardFtpTitle"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="FTP Manager"
                        android:textColor="#FFFFFF" android:textStyle="bold" android:textSize="14sp"/>
                    <TextView
                        android:id="@+id/tvCardFtpSub"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Conectar PS3 vía webMAN / MultiMAN"
                        android:textColor="#666666" android:textSize="11sp"/>
                </LinearLayout>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="›" android:textColor="#444444" android:textSize="22sp"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Footer -->
        <TextView
            android:id="@+id/tvFooter"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="PKGs extraídos → Android/data/com.kizeo.kzstorereader/files/data/"
            android:textColor="#2A2A2A"
            android:textSize="9sp"
            android:fontFamily="monospace"
            android:gravity="center"
            android:paddingTop="12dp"/>

    </LinearLayout>
</androidx.core.widget.NestedScrollView>