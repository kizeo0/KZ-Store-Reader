<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">

    <style name="Theme.KZStoreReader" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/ps3_accent_blue</item>
        <item name="colorPrimaryVariant">@color/ps3_surface</item>
        <item name="colorOnPrimary">@color/ps3_text_primary</item>
        <item name="colorSecondary">@color/ps3_accent_green</item>
        <item name="colorOnSecondary">@color/ps3_bg</item>
        <item name="android:colorBackground">@color/ps3_bg</item>
        <item name="android:windowBackground">@color/ps3_bg</item>
        <item name="android:statusBarColor">@color/ps3_surface</item>
        <item name="android:navigationBarColor">@color/ps3_bg</item>
        <item name="android:windowLightStatusBar" tools:targetApi="23">false</item>
        <item name="android:textColor">@color/ps3_text_primary</item>
        <item name="toolbarStyle">@style/KZToolbarStyle</item>
    </style>

    <style name="KZToolbarStyle" parent="Widget.AppCompat.Toolbar">
        <item name="android:background">@color/ps3_surface</item>
        <item name="titleTextColor">@color/ps3_text_primary</item>
        <item name="subtitleTextColor">@color/ps3_text_secondary</item>
    </style>

</resources>
